# ============================================================
# SocialLab — Environment Configuration
# ============================================================
# Cada variable tiene el valor LOCAL por defecto.
# Para migrar a cloud, cambia solo el valor — no se toca código.
# ============================================================

# --- MongoDB ---
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net
MONGO_URI=mongodb://localhost:27017
MONGO_DB=sociallab

# --- Neo4j ---
# Local:  bolt://localhost:7687
# Aura:   neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Data Lake ---
# Local:  ./data
# DBFS:   /dbfs/mnt/sociallab  o  abfss://container@account.dfs.core.windows.net/sociallab
DATA_LAKE_PATH=./data

# --- Spark ---
# Local:  local[*]
# Databricks: (no se usa, Databricks provee su propio SparkSession)
SPARK_MASTER=local[*]

# --- Web ---
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_DEBUG=true

# --- General ---
ENV=local
LOG_LEVEL=INFO
