# Quasar — configuracion para `docker compose up` (todas las apps).
# Las URIs apuntan a los nombres de servicio del compose, no a localhost.

MONGO_URI=mongodb://mongodb:27017
MONGO_DB=sociallab

NEO4J_URI=neo4j://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jneo4j

DATA_LAKE_PATH=/app/data
SPARK_MASTER=local[*]

WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_DEBUG=true

ENV=docker
LOG_LEVEL=INFO

# --- Modo laboratorio ---
# Lista, separada por comas, de bloques DESBLOQUEADOS (con solucion activa).
# Lo no listado se sirve como scaffold (ejercicio para el alumno).
#
# Bloques Cypher:    basic, intermediate, advanced
# Bloques ML:        supervised, unsupervised, graph_ml
# Atajo:             all (desbloquea todo)
#
# Ejemplos:
#   LAB_NEO4J=                     → todo Neo4j en scaffold (default alumno)
#   LAB_NEO4J=basic                → bloque basic resuelto, intermediate+advanced scaffold
#   LAB_NEO4J=basic,intermediate   → progresion clase a clase
#   LAB_NEO4J=all                  → todo Neo4j resuelto
#
# Para cambiar en caliente: ./lab.sh sociallab unlock neo4j basic  (reinicia solo el contenedor app)
LAB_NEO4J=
LAB_ML=

# --- Modo laboratorio (PreproLab) ---
# Bloques: eda | missing | outliers | integration | transform | normalize | reduce_dim | reduce_inst
# Atajo:   all
LAB_PREPROLAB=

# --- Modo laboratorio (LLM Lab) ---
# Bloques: clean | dedup | tokenize | train
# Atajo:   all
LAB_LLMPREP=
