# ============================================================
# SocialLab — Environment Configuration (modo nativo).
# ============================================================
# Para arranque Docker, el archivo equivalente es infra/compose/.env.docker
# Para migrar a cloud, copia .env.cloud.example a .env.cloud y rellena URIs.
# ============================================================

# --- MongoDB ---
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net
MONGO_URI=mongodb://localhost:27017
MONGO_DB=sociallab

# --- Neo4j ---
# Local:  bolt://localhost:7687
# Aura:   neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Data Lake ---
# Vacio = default Quasar: <repo>/infra/data/sociallab/{raw,silver,gold}
# Para sobreescribir: pon ruta absoluta o relativa a la raiz del repo.
# Ejemplos:
#   DATA_LAKE_PATH=                                    -> usa el default
#   DATA_LAKE_PATH=/Users/<user>/Datos/sociallab       -> ruta absoluta
#   DATA_LAKE_PATH=/dbfs/mnt/sociallab                 -> DBFS Databricks
DATA_LAKE_PATH=

# --- Spark ---
# Local:  local[*]
# Databricks: (no se usa, Databricks provee su propio SparkSession)
SPARK_MASTER=local[*]

# --- Web ---
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_DEBUG=true

# --- General ---
ENV=local
LOG_LEVEL=INFO
