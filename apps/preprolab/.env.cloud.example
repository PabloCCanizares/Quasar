# PreproLab — configuracion cloud (modo 100% free).
#
# Uso:
#   cp .env.cloud.example .env.cloud
#   # rellena los <placeholders> con tus credenciales reales
#   ./lab.sh preprolab cloud
#
# PreproLab usa MongoDB para metadatos/metricas y el data lake local para
# el dataset de robots. No usa Neo4j (de momento), asi que las credenciales
# Neo4j son opcionales.

# --- MongoDB Atlas M0 (free) ---
MONGO_URI=mongodb+srv://preprolab_app:<password>@preprolab-cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=preprolab

# --- Neo4j AuraDB Free (opcional, PreproLab no lo usa todavia) ---
NEO4J_URI=neo4j+s://<dbid>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<password>

# --- Data Lake ---
# El dataset de robots se genera localmente. Deja vacio para usar el default
# (<repo>/infra/data/preprolab).
DATA_LAKE_PATH=
SPARK_MASTER=local[*]

# --- Web ---
WEB_HOST=0.0.0.0
WEB_PORT=8002
WEB_DEBUG=true

# --- Modo laboratorio ---
# Bloques: eda | missing | outliers | integration | transform | normalize | reduce_dim | reduce_inst
# Atajo:   all
# Por defecto vacio = todo en modo ejercicio (scaffold).
LAB_PREPROLAB=

# --- General ---
ENV=cloud
LOG_LEVEL=INFO
