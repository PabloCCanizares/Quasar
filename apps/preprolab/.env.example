# ============================================================
# PreproLab — Environment Configuration (modo nativo).
# ============================================================
# Para arranque Docker, la configuración común vive en
# infra/compose/.env.docker (y el WEB_PORT/MONGO_DB específico
# de cada app se hardcodea en docker-compose.yml).
# ============================================================

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=preprolab

# --- Neo4j (Fase posterior, no obligatorio para los primeros bloques) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Data Lake ---
# Vacio = default Quasar: <repo>/infra/data/preprolab/{raw,silver,gold}
DATA_LAKE_PATH=

# --- Spark ---
SPARK_MASTER=local[*]

# --- Web ---
WEB_HOST=0.0.0.0
WEB_PORT=8002
WEB_DEBUG=true

# --- General ---
ENV=local
LOG_LEVEL=INFO

# --- Modo laboratorio (PreproLab) ---
# Bloques desbloqueados (resueltos). Lo no listado se sirve como scaffold.
# Bloques: eda | missing | outliers | integration | transform | normalize | reduce_dim | reduce_inst
# Atajo:   all
LAB_PREPROLAB=
