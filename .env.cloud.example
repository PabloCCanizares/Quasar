# SocialLab — configuracion cloud (modo 100% free).
#
# Uso:
#   cp .env.cloud.example .env.cloud
#   # rellena los <placeholders> con tus credenciales reales
#   ./lab.sh cloud   (o copiar .env.cloud a .env y `python main.py`)
#
# Guia paso a paso para conseguir cada URI: docs/MIGRACION_CLOUD.md

# --- MongoDB Atlas M0 (free) ---
# Obtener en: https://cloud.mongodb.com -> Database -> Connect -> Drivers
MONGO_URI=mongodb+srv://sociallab_app:<password>@sociallab-cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=sociallab

# --- Neo4j AuraDB Free ---
# URI y password vienen en el fichero descargado al crear la instancia
# (solo se muestra UNA vez al crear la base de datos)
NEO4J_URI=neo4j+s://<dbid>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<password>

# --- Data Lake ---
# En modo cloud el lake real vive en Databricks DBFS (dbfs:/FileStore/sociallab).
# La app FastAPI solo accede a Mongo y Neo4j directamente, no al lake — pero
# necesita un path local valido para que `config.py` no peta. Deja ./data.
DATA_LAKE_PATH=./data
SPARK_MASTER=local[*]

# --- Web ---
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_DEBUG=true

# --- Modo laboratorio ---
# Lista de bloques DESBLOQUEADOS (con solucion activa). Igual que en .env.docker.
# Bloques Cypher:    basic, intermediate, advanced
# Bloques ML:        supervised, unsupervised, graph_ml
# Atajo:             all (desbloquea todo)
#
# Por defecto vacios = todo en modo ejercicio (scaffold).
LAB_NEO4J=
LAB_ML=

# --- General ---
ENV=cloud
LOG_LEVEL=INFO
